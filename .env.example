DATABASE_URL=postgresql+asyncpg://user:password@db:5432/pcf

JWT_SECRET_KEY=change_me_please_with_very_long_secret_key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pcf-files
MINIO_USE_SSL=false

BACKEND_CORS_ORIGINS=http://localhost:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

COOKIE_SECURE=false
COOKIE_SAMESITE=strict
CSRF_ALLOWED_ORIGINS=http://localhost:3000

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@local
INITIAL_ADMIN_PASSWORD=admin

AUDIT_LOG_BACKEND=clickhouse
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=pcf
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false

RABBITMQ_URL=amqp://guest:guest@rabbitmq/
MAIL_QUEUE_NAME=pcf.mail
MAIL_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PCF
