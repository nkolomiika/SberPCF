DATABASE_URL=postgresql+asyncpg://user:password@db:5432/pcf

JWT_SECRET_KEY=change_me_please_with_very_long_secret_key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pcf-files
MINIO_USE_SSL=false

BACKEND_CORS_ORIGINS=https://localhost:3000,https://127.0.0.1:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

COOKIE_SECURE=true
COOKIE_SAMESITE=strict
CSRF_ALLOWED_ORIGINS=https://localhost:3000,https://127.0.0.1:3000

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@local
INITIAL_ADMIN_PASSWORD=admin

RABBITMQ_URL=amqp://guest:guest@rabbitmq/
MAIL_QUEUE_NAME=pcf.mail
MAIL_ENABLED=true
MAIL_MAX_ATTEMPTS=5

# ──────────────── Рекон-ферма (пробив списков хостов и IP) ────────────────
# Прогонять задачи через RabbitMQ и контейнер recon-worker (docker-compose).
# false — прогон в процессе API через BackgroundTasks: для разработки без RabbitMQ.
RECON_WORKER_ENABLED=true
RECON_QUEUE_NAME=recon
RECON_MAX_ATTEMPTS=3
# Обратный резолв (PTR + forward-confirm) при импорте IP. На изолированном
# стенде без DNS выключите, иначе каждый адрес будет ждать таймаута.
FARM_REVERSE_DNS_ENABLED=true
FARM_REVERSE_DNS_TIMEOUT_SECONDS=3.0
# Ферма ходит только во внешнюю сеть (SSRF-guard). Включать осознанно.
FARM_ALLOW_PRIVATE_TARGETS=false
# Импорт IP: подтверждённые PTR-имена адреса прогонять фермой хостов (искать их
# веб-порты и сервисы) и заводить полноценным хостом.
FARM_IP_RESOLVE_HOSTS_ENABLED=true
# Определение технологий и CDN веб-порта при пробиве (сервисы + флаг Cloudflare).
# Выключите, если инструменты не установлены, — порты останутся «unknown».
SERVICES_DETECT_ENABLED=true
# Движок: httpx (ProjectDiscovery, быстрее/точнее) | whatweb (запасной).
SERVICES_DETECT_ENGINE=httpx
SERVICES_DETECT_TIMEOUT_SECONDS=20.0

# ──────────────── SMTP ────────────────
# Способ аутентификации: "password" (обычный SMTP AUTH) или "xoauth2" (OAuth2, профиль 4).
SMTP_AUTH_METHOD=password
#
# Поддерживаются 4 профиля. Раскомментируйте нужный, остальные оставьте закомментированными.
# SMTP_USE_TLS=true  — STARTTLS (порт 587, Gmail/корпоративные)
# SMTP_USE_SSL=true  — implicit SSL (порт 465)
# Оба false        — открытый SMTP (только локально, например mailpit)

# ── 1) Локальная разработка через mailpit (по умолчанию)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PCF

# ── 2) Тестовая отправка через Gmail
# Для Gmail нужен «App password» (требует 2FA на аккаунте):
#   Google Account → Security → 2-Step Verification → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-account@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_FROM_EMAIL=your-account@gmail.com
# SMTP_FROM_NAME=PCF

# ── 3) Корпоративная учётка @sbertech (продакшен)
# Реальные хост/порт уточняются у админов почты, ниже — типовой шаблон.
# SMTP_HOST=smtp.sbertech.ru
# SMTP_PORT=587
# SMTP_USERNAME=pcf-noreply@sbertech.ru
# SMTP_PASSWORD=<секрет из vault>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_FROM_EMAIL=pcf-noreply@sbertech.ru
# SMTP_FROM_NAME=PCF

# ── 4) Отправка от лица Gmail-аккаунта через OAuth2 (XOAUTH2)
# В отличие от профиля 2, не требует App Password — доступ выдаётся через
# экран согласия Google. Порядок настройки:
#   1) Google Cloud Console: OAuth client типа «Web», в Authorized redirect URIs
#      добавить  http://localhost:8765/oauth2callback
#   2) Заполнить GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET ниже
#   3) python backend/scripts/google_oauth_setup.py  → получить refresh token
#   4) Вставить GOOGLE_OAUTH_REFRESH_TOKEN и раскомментировать блок ниже
# SMTP_AUTH_METHOD=xoauth2
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USERNAME=your-account@gmail.com
# SMTP_FROM_EMAIL=your-account@gmail.com
# SMTP_FROM_NAME=PCF
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxx
# GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxx

# URL веб-интерфейса для просмотра писем в dev (mailpit). В проде не используется.
MAIL_PREVIEW_URL=http://localhost:8025
