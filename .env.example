DATABASE_URL=postgresql+asyncpg://user:password@db:5432/pcf

JWT_SECRET_KEY=change_me_please_with_very_long_secret_key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pcf-files
MINIO_USE_SSL=false

BACKEND_CORS_ORIGINS=https://localhost:3000,https://127.0.0.1:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

COOKIE_SECURE=true
COOKIE_SAMESITE=strict
CSRF_ALLOWED_ORIGINS=https://localhost:3000,https://127.0.0.1:3000

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@local
INITIAL_ADMIN_PASSWORD=admin

RABBITMQ_URL=amqp://guest:guest@rabbitmq/
MAIL_QUEUE_NAME=pcf.mail
MAIL_ENABLED=true
MAIL_MAX_ATTEMPTS=5

# ──────────────── SMTP ────────────────
# Поддерживаются 3 профиля. Раскомментируйте нужный, остальные оставьте закомментированными.
# SMTP_USE_TLS=true  — STARTTLS (порт 587, Gmail/корпоративные)
# SMTP_USE_SSL=true  — implicit SSL (порт 465)
# Оба false        — открытый SMTP (только локально, например mailpit)

# ── 1) Локальная разработка через mailpit (по умолчанию)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=PCF

# ── 2) Тестовая отправка через Gmail
# Для Gmail нужен «App password» (требует 2FA на аккаунте):
#   Google Account → Security → 2-Step Verification → App passwords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-account@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_FROM_EMAIL=your-account@gmail.com
# SMTP_FROM_NAME=PCF

# ── 3) Корпоративная учётка @sbertech (продакшен)
# Реальные хост/порт уточняются у админов почты, ниже — типовой шаблон.
# SMTP_HOST=smtp.sbertech.ru
# SMTP_PORT=587
# SMTP_USERNAME=pcf-noreply@sbertech.ru
# SMTP_PASSWORD=<секрет из vault>
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_FROM_EMAIL=pcf-noreply@sbertech.ru
# SMTP_FROM_NAME=PCF

# URL веб-интерфейса для просмотра писем в dev (mailpit). В проде не используется.
MAIL_PREVIEW_URL=http://localhost:8025
