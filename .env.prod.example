# ─────────────────────────────────────────────────────────────────────────────
# STORM — ШАБЛОН ПРОД-ОКРУЖЕНИЯ. Скопируйте в .env.prod и подставьте значения.
#   cp .env.prod.example .env.prod   &&   $EDITOR .env.prod
# .env.prod в git не попадает (см. .gitignore) — там реальные секреты.
# ─────────────────────────────────────────────────────────────────────────────
# Запуск:
#   dev :  docker compose up -d                                   (берёт .env)
#   prod:  ./deploy.sh                                            (берёт .env.prod)
#     └ то же вручную: ENV_FILE=.env.prod docker compose \
#           -f docker-compose.yml -f docker-compose.prod.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://user:password@db:5432/pcf

# ОБЯЗАТЕЛЬНО поменяйте: минимум 32 символа.
JWT_SECRET_KEY=change_me_please_with_very_long_secret_key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=pcf-files
MINIO_USE_SSL=false

# Публичный адрес сервера. По IP: https://<IP>. По домену: https://storm.example.com
# Добавили домен — впишите его и сюда, и в CSRF_ALLOWED_ORIGINS, иначе вход/POST → 403.
BACKEND_CORS_ORIGINS=https://SERVER_ADDR,https://SERVER_ADDR:3000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=false

COOKIE_SECURE=true
COOKIE_SAMESITE=strict
CSRF_ALLOWED_ORIGINS=https://SERVER_ADDR,https://SERVER_ADDR:3000

# База для ссылок в письмах. Должна быть доступна ПОЛУЧАТЕЛЮ письма (не localhost).
APP_BASE_URL=https://SERVER_ADDR

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me

RABBITMQ_URL=amqp://guest:guest@rabbitmq/
MAIL_QUEUE_NAME=pcf.mail
MAIL_ENABLED=true
MAIL_MAX_ATTEMPTS=5

# SMTP: в проде — реальная отправка. Пример Gmail через OAuth2 (XOAUTH2).
SMTP_AUTH_METHOD=xoauth2
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-account@gmail.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_FROM_EMAIL=your-account@gmail.com
SMTP_FROM_NAME=STORM
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

MAIL_PREVIEW_URL=http://localhost:8025

# Jira (опционально).
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_DEFAULT_PROJECT_KEY=
JIRA_DEFAULT_ISSUE_TYPE=Task
JIRA_ENABLED=false
JIRA_START_DATE_FIELD=customfield_10015
JIRA_DUE_IN_DAYS=14

# TLS self-signed: адрес в SAN, чтобы сертификат соответствовал URL.
# По IP — заполните CERT_IP. По домену — CERT_HOST (CERT_IP оставьте пустым).
CERT_IP=SERVER_ADDR
CERT_HOST=
