    "@tiptap/pm": "^2.10.4",
    "@tiptap/react": "^2.10.4",
    "@tiptap/starter-kit": "^2.10.4",
    "axios": "^1.8.4",
    "js-yaml": "^4.1.1",
    "react": "^18.3.1",
